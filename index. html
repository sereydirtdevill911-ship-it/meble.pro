<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Konfigurator PRO – R2.4.2</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Syne:wght@400;600;700&display=swap');

:root{
  --bg:#0f1117;
  --surface:#1a1d27;
  --surface2:#22263a;
  --border:#2e3350;
  --accent:#4f8ef7;
  --accent2:#f7c14f;
  --danger:#f74f4f;
  --success:#4ff7a0;
  --text:#e8ecf5;
  --muted:#7a829e;
  --radius:8px;
}

*{box-sizing:border-box;margin:0;padding:0;}

body{
  font-family:'Syne',sans-serif;
  background:var(--bg);
  color:var(--text);
  min-height:100vh;
  padding:24px 16px;
}

.container{
  max-width:960px;
  margin:auto;
}

h1{
  font-size:1.4rem;
  font-weight:700;
  letter-spacing:.04em;
  color:var(--text);
  padding:18px 22px;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  margin-bottom:20px;
  display:flex;
  align-items:center;
  gap:10px;
}

h1 span.badge{
  font-family:'JetBrains Mono',monospace;
  font-size:.7rem;
  background:var(--accent);
  color:#fff;
  padding:3px 8px;
  border-radius:4px;
  letter-spacing:.06em;
}

.grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:16px;
  margin-bottom:16px;
}
.grid2{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
}
@media(max-width:640px){.grid{grid-template-columns:1fr;}.grid2{grid-template-columns:1fr;}}

.card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:16px 18px;
}

.card h3{
  font-size:.75rem;
  text-transform:uppercase;
  letter-spacing:.1em;
  color:var(--muted);
  margin-bottom:14px;
}

label{
  display:block;
  font-size:.78rem;
  color:var(--muted);
  margin-bottom:5px;
  margin-top:12px;
  letter-spacing:.04em;
}

label:first-of-type{margin-top:0;}

select,input[type=number]{
  width:100%;
  padding:9px 12px;
  background:var(--surface2);
  border:1px solid var(--border);
  border-radius:6px;
  color:var(--text);
  font-family:'Syne',sans-serif;
  font-size:.85rem;
  outline:none;
  transition:border-color .2s;
}

select:focus,input:focus{border-color:var(--accent);}

.buttons{
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:10px;
  margin-top:16px;
}

button{
  padding:11px 14px;
  border:none;
  border-radius:6px;
  font-family:'Syne',sans-serif;
  font-weight:600;
  font-size:.82rem;
  cursor:pointer;
  transition:opacity .2s,transform .1s;
  letter-spacing:.03em;
}

button:hover{opacity:.88;}
button:active{transform:scale(.98);}

.btn-primary{background:var(--accent);color:#fff;grid-column:1/-1;}
.btn-secondary{background:var(--surface2);color:var(--text);border:1px solid var(--border);}
.btn-success{background:var(--success);color:#0f1117;}
.btn-danger{background:var(--danger);color:#fff;}
.btn-view-active{background:var(--accent2)!important;color:#0f1117!important;}

.drawer-block{
  background:var(--surface2);
  border:1px solid var(--border);
  border-radius:6px;
  padding:10px 12px;
  margin-bottom:8px;
}

.drawer-block strong{
  font-size:.78rem;
  color:var(--accent2);
}

/* Result */
.result-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:18px;
  margin-top:16px;
}

.result-card h2{
  font-size:.9rem;
  text-transform:uppercase;
  letter-spacing:.1em;
  color:var(--muted);
  margin-bottom:14px;
}

table{
  width:100%;
  border-collapse:collapse;
  font-family:'JetBrains Mono',monospace;
  font-size:.78rem;
}

th{
  background:var(--surface2);
  color:var(--muted);
  padding:8px 10px;
  text-align:left;
  font-size:.72rem;
  letter-spacing:.08em;
  text-transform:uppercase;
  border-bottom:1px solid var(--border);
}

td{
  padding:7px 10px;
  border-bottom:1px solid var(--border);
  color:var(--text);
}

tr:last-child td{border-bottom:none;}
tr:hover td{background:var(--surface2);}

.warn{
  background:rgba(247,79,79,.12);
  border:1px solid var(--danger);
  border-radius:6px;
  padding:12px 14px;
  color:var(--danger);
  font-size:.85rem;
  font-weight:600;
  margin-top:12px;
}

.warn::before{content:"⚠ ";}

.info-row td:first-child{color:var(--accent2);}

#drawerSection{display:none;}

.btn-tab{
  padding:6px 14px;
  background:var(--surface2);
  border:1px solid var(--border);
  border-radius:6px;
  color:var(--muted);
  font-family:'Syne',sans-serif;
  font-size:.75rem;
  font-weight:600;
  cursor:pointer;
  transition:all .2s;
}
.btn-tab.active{
  background:var(--accent);
  border-color:var(--accent);
  color:#fff;
}
</style>
</head>
<body>
<div class="container">

<h1>Konfigurator PRO <span class="badge">R2.5.0 + 2D</span></h1>

<!-- G&#322;&#243;wne zak&#322;adki -->
<div style="display:flex;gap:8px;margin-bottom:16px;">
  <button id="mainTabKonfig" onclick="switchMainTab('konfig')" style="flex:1;padding:10px;border-radius:8px;font-family:'Syne',sans-serif;font-weight:700;font-size:.85rem;cursor:pointer;border:2px solid var(--accent);background:var(--accent);color:#fff;">⚙ Konfigurator</button>
  <button id="mainTabRozm" onclick="switchMainTab('rozm')" style="flex:1;padding:10px;border-radius:8px;font-family:'Syne',sans-serif;font-weight:700;font-size:.85rem;cursor:pointer;border:2px solid var(--border);background:var(--surface2);color:var(--text);">📐 Rozmiarka</button>
</div>

<!-- SEKCJA KONFIGURATOR -->
<div id="sectionKonfig">

  <!-- Lewa kolumna -->
  <div class="card">
    <h3>Typ szafy</h3>

    <label>Typ korpusu</label>
    <select id="type" onchange="autoLogic()">
      <option>Dolna</option>
      <option>Dolna GOLA</option>
      <option>Wisz&#261;ca</option>
      <option>Pod zmywark&#281;</option>
      <option>Pod lod&#243;wk&#281;</option>
    </select>

    <label>Konstrukcja</label>
    <select id="config" onchange="updateDrawerSelectors()">
      <option>Drzwi</option>
      <option>Szuflady</option>
    </select>

    <label>Ilo&#347;&#263; front&#243;w (tylko dla Drzwi)</label>
    <select id="frontCount">
      <option value="1">1</option>
      <option value="2">2</option>
    </select>
  </div>

  <!-- Prawa kolumna -->
  <div class="card">
    <h3>Wymiary (mm)</h3>

    <label>Wysoko&#347;&#263;</label>
    <input type="number" id="height" value="720" min="300" max="2400" oninput="updateDrawerSelectors()">

    <label>Szeroko&#347;&#263;</label>
    <input type="number" id="width" value="600" min="300" max="1200">

    <label>G&#322;&#281;boko&#347;&#263;</label>
    <input type="number" id="depth" value="560" min="200" max="800">
  </div>

</div>

<!-- Szuflady section -->
<div class="card" id="drawerSection" style="margin-bottom:16px;">
  <h3>Szuflady</h3>

  <div class="grid">
    <div>
      <label>System szuflad</label>
      <select id="system" onchange="updateDrawerSelectors()">
        <option>Antaro</option>
        <option>Tandembox</option>
        <option>Merivobox</option>
        <option>Legrabox</option>
      </select>
    </div>
    <div>
      <label>Prowadnica (mm)</label>
      <select id="runner">
        <option>450</option>
        <option selected>500</option>
        <option>550</option>
      </select>
    </div>
  </div>

  <!-- Ukryte pole qty — sterowane przez przyciski -->
  <input type="hidden" id="qty" value="3">

  <label style="margin-top:12px;">Uk&#322;ad szuflad</label>
  <div id="layoutBtns" style="display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;"></div>

  <div id="frontHSum" style="margin-top:10px;padding:8px 12px;background:var(--surface2);border-radius:6px;font-size:.78rem;font-family:'JetBrains Mono',monospace;border:1px solid var(--border);display:none;"></div>

  <div id="drawerSelectors" style="margin-top:12px;"></div>
</div>

<!-- Wisz&#261;ca shelves -->
<div class="card" id="shelvesCard" style="margin-bottom:16px;display:none;">
  <h3>P&#243;&#322;ki (Wisz&#261;ca)</h3>
  <label>Ilo&#347;&#263; p&#243;&#322;ek wewn&#281;trznych</label>
  <input type="number" id="shelfCount" value="1" min="0" max="6">
</div>

<div class="buttons">
  <button class="btn-primary" onclick="calculate()">🔧 Oblicz</button>
  <button class="btn-success" onclick="addModule()">➕ Dodaj modu&#322;</button>
  <button class="btn-secondary" onclick="showProject()">📊 Poka&#380; projekt</button>
  <button class="btn-danger" onclick="clearProject()">🗑 Wyczy&#347;&#263; projekt</button>
</div>

<div id="result"></div>

<div id="canvasWrap" class="result-card" style="display:none;margin-top:16px;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
    <h2 style="margin:0;">2D – Widok</h2>
    <div style="display:flex;gap:8px;">
      <button class="btn-tab active" id="tabFront" onclick="switchView('front')">⬜ Prz&#243;d</button>
      <button class="btn-tab" id="tabSide"  onclick="switchView('side')">◻ Bok</button>
    </div>
  </div>
  <canvas id="corpusCanvas" style="width:100%;border-radius:6px;background:#0a0d14;display:block;"></canvas>
  <div id="canvasLegend" style="margin-top:12px;display:flex;flex-wrap:wrap;gap:10px;font-size:.72rem;font-family:'JetBrains Mono',monospace;color:var(--muted);"></div>
</div>

<div id="projectView"></div>

</div><!-- /sectionKonfig -->

<!-- SEKCJA ROZMIARKA -->
<div id="sectionRozm" style="display:none;">

  <div class="card">
    <h3>📏 Rozmiarka boku</h3>
    <p style="font-size:.75rem;color:var(--muted);margin-bottom:12px;">R&#1091;&#1083;&#1077;&#1090;&#1082;&#1072; od wie&#324;ca dolnego (0mm) do g&#243;rnego. Wpisz wymiary → dostaniesz list&#281; metek.</p>

    <label>Wysoko&#347;&#263; formatki (boku)</label>
    <input type="number" id="rm_height" value="760" min="300" max="2400" oninput="calcRozm()">

    <label style="margin-top:14px;">Szuflady — wysoko&#347;ci front&#243;w (od do&#322;u, przez spacj&#281; lub przecinek)</label>
    <input type="text" id="rm_drawers" placeholder="np. 304 304 141" oninput="calcRozm()"
      style="width:100%;padding:9px 12px;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:.9rem;outline:none;">
    <div id="rm_drawer_preview" style="font-size:.72rem;color:var(--muted);margin-top:4px;"></div>

    <label style="margin-top:14px;">P&#243;&#322;ki — pozycje od wie&#324;ca dolnego (przez spacj&#281; lub przecinek)</label>
    <input type="text" id="rm_shelves" placeholder="np. 200 400" oninput="calcRozm()"
      style="width:100%;padding:9px 12px;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:.9rem;outline:none;">

    <div class="grid2" style="margin-top:12px;gap:10px;">
      <div>
        <label>Zazor mi&#281;dzy frontami</label>
        <input type="number" id="rm_gap_front" value="3" min="0" max="10" oninput="calcRozm()">
      </div>
      <div>
        <label>Luz techniczny</label>
        <input type="number" id="rm_gap_tech" value="9" min="0" max="20" oninput="calcRozm()">
      </div>
    </div>
  </div>

  <!-- Wynik -->
  <div id="rm_result"></div>

</div><!-- /sectionRozm -->

</div><!-- /container -->

<script>
const systemData={
  Antaro:   {types:{N:68,M:84,C:148,D:196}, offset:38, minWidth:300},
  Tandembox:{types:{N:68,M:84,C:148,D:196}, offset:38, minWidth:300},
  Merivobox:{types:{E:90,M:130,K:180,H:250},offset:42, minWidth:350},
  Legrabox: {types:{N:66,M:90,C:177,F:241}, offset:38, minWidth:300}
};

let project=[];

/* ===== AUTO LOGIC ===== */
function autoLogic(){
  const t=document.getElementById("type").value;
  const cfgEl=document.getElementById("config");
  const heightEl=document.getElementById("height");
  const depthEl=document.getElementById("depth");
  const shelvesCard=document.getElementById("shelvesCard");

  // Typy bez szuflad
  if(t==="Wisz&#261;ca"||t==="Pod zmywark&#281;"||t==="Pod lod&#243;wk&#281;"){
    cfgEl.value="Drzwi";
    cfgEl.disabled=true;
  } else {
    cfgEl.disabled=false;
  }

  // Presets wymiar&#243;w
  if(t==="Wisz&#261;ca")     {heightEl.value=720;  depthEl.value=320;}
  if(t==="Pod zmywark&#281;"){heightEl.value=720;  depthEl.value=560;}
  if(t==="Pod lod&#243;wk&#281;") {heightEl.value=2130; depthEl.value=600;}
  if(t==="Dolna"||t==="Dolna GOLA"){heightEl.value=720;depthEl.value=560;}

  // FIX: pokazuj sekcj&#281; p&#243;&#322;ek tylko dla Wisz&#261;ca
  shelvesCard.style.display=(t==="Wisz&#261;ca")?"block":"none";

  updateDrawerSelectors();
}

/* ===== LAYOUT  ( + ) ===== */
const LAYOUTS=[
  {id:"1",    label:"1",     qty:1, dist:"equal",  desc:"Jedna szuflada"},
  {id:"2eq",  label:"2",     qty:2, dist:"equal",  desc:"2 r&#243;wne"},
  {id:"3eq",  label:"3",     qty:3, dist:"equal",  desc:"3 r&#243;wne"},
  {id:"2+1",  label:"2+1",   qty:3, dist:"2big1sm", desc:"2 du&#380;e na dole + 1 ma&#322;a na g&#243;rze"},
  {id:"1+2",  label:"1+2",   qty:3, dist:"1sm2big", desc:"1 ma&#322;a na g&#243;rze + 2 du&#380;e na dole"},
  {id:"4eq",  label:"4",     qty:4, dist:"equal",   desc:"4 r&#243;wne"},
  {id:"2+2",  label:"2+2",   qty:4, dist:"2big2sm",  desc:"2 du&#380;e + 2 ma&#322;e (ma&#322;e na dole)"},
  {id:"3+1",  label:"3+1",   qty:4, dist:"3big1sm",  desc:"3 du&#380;e + 1 ma&#322;a (ma&#322;a na dole)"},
];

let activeLayout="3eq";

function renderLayoutButtons(){
  const wrap=document.getElementById("layoutBtns");
  if(!wrap) return;
  wrap.innerHTML="";
  LAYOUTS.forEach(l=>{
    const btn=document.createElement("button");
    btn.textContent=l.label;
    btn.title=l.desc;
    const isActive=l.id===activeLayout;
    btn.style.cssText=`padding:8px 16px;border-radius:6px;font-family:'Syne',sans-serif;font-weight:700;font-size:.85rem;cursor:pointer;transition:all .15s;border:2px solid ${isActive?"var(--accent)":"var(--border)"};background:${isActive?"var(--accent)":"var(--surface2)"};color:${isActive?"#fff":"var(--text)"};`;
    btn.onclick=()=>{
      activeLayout=l.id;
      document.getElementById("qty").value=l.qty;
      renderLayoutButtons();
      updateDrawerSelectors();
      //    dist-  
      applyLayoutDist(l);
    };
    wrap.appendChild(btn);
  });
}

function applyLayoutDist(layout){
  const H=parseInt(document.getElementById("height").value)||720;
  const golaOffset=(document.getElementById("type").value==="Dolna GOLA")?50:0;
  const qty=layout.qty;
  const available=H-golaOffset-4-((qty-1)*3);

  let heights=[];
  if(layout.dist==="equal"){
    const eq=Math.floor(available/qty);
    heights=Array(qty-1).fill(eq).concat([available-(qty-1)*eq]);
  } else if(layout.dist==="2big1sm"){
    // 2+1:   ,  
    const sm=Math.max(100, Math.floor(available*0.16));
    const big=Math.floor((available-sm)/2);
    heights=[big, big, sm]; // [, ,  ]
  } else if(layout.dist==="1sm2big"){
    // 1+2:  ,   
    const sm=Math.max(100, Math.floor(available*0.16));
    const big=Math.floor((available-sm)/2);
    heights=[sm, big, available-sm-big]; // [, , ]
  } else if(layout.dist==="2big2sm"){
    // 2+2: +++ ( )
    const sm=Math.max(100, Math.floor(available*0.13));
    const big=Math.floor((available-sm*2)/2);
    heights=[big, big, sm, available-big*2-sm];
  } else if(layout.dist==="3big1sm"){
    // 3+1: +++ ( )
    const sm=Math.max(100, Math.floor(available*0.13));
    const big=Math.floor((available-sm)/3);
    heights=[big, big, big, available-big*3];
  }

  heights.forEach((h,i)=>{
    const el=document.getElementById("drawerFrontH_"+(i+1));
    if(el) el.value=Math.max(100,h);
  });
  updateHeightSum();
}

/* ===== P  ===== */
function getPresets(qty, available){
  const a=available;
  const presets=[];

  if(qty===1){
    presets.push({label:"1 szuflada", heights:[a]});
  }

  if(qty===2){
    const eq=Math.floor(a/2);
    presets.push({label:"2 r&#243;wne", heights:[eq, a-eq]});
    const big=Math.floor(a*0.67), small=a-big;
    if(small>=100) presets.push({label:"Du&#380;a + ma&#322;a", heights:[big, small]});
  }

  if(qty===3){
    const eq=Math.floor(a/3);
    presets.push({label:"3 r&#243;wne", heights:[eq, eq, a-eq*2]});
    // 2 du&#380;e + 1 ma&#322;a (ma&#322;a na g&#243;rze = szuflada 1)
    const big=Math.floor(a*0.42), small=a-big*2;
    if(small>=100 && big>=100) presets.push({label:"2 du&#380;e + ma&#322;a", heights:[big, big, small]});
    // 1 ma&#322;a + 2 du&#380;e (ma&#322;a na dole = szuflada 1)
    const big2=Math.floor((a-small)/2);
    if(small>=100 && big2>=100) presets.push({label:"Ma&#322;a + 2 du&#380;e", heights:[small, big2, a-small-big2]});
  }

  if(qty===4){
    const eq=Math.floor(a/4);
    presets.push({label:"4 r&#243;wne", heights:[eq,eq,eq,a-eq*3]});
    const big=Math.floor(a*0.3), small=Math.floor((a-big*2)/2);
    if(small>=100&&big>=100) presets.push({label:"2×du&#380;e + 2×ma&#322;e", heights:[small,small,big,a-small*2-big]});
  }

  if(qty>=5){
    const eq=Math.floor(a/qty);
    presets.push({label:`${qty} r&#243;wnych`, heights:Array(qty-1).fill(eq).concat([a-(qty-1)*eq])});
  }

  // Zawsze dodaj "W&#322;asny" jako reset do auto
  return presets;
}

function applyPreset(heights){
  heights.forEach((h,i)=>{
    const el=document.getElementById("drawerFrontH_"+(i+1));
    if(el) el.value=h;
  });
  // Highlight active preset
  document.querySelectorAll('.preset-btn').forEach(b=>b.classList.remove('preset-active'));
  event.target.classList.add('preset-active');
  updateHeightSum();
}

/* ===== SZUFLADY SELECTORS ===== */
function updateDrawerSelectors(){
  const config=document.getElementById("config").value;
  const drawerSection=document.getElementById("drawerSection");
  const qty=parseInt(document.getElementById("qty").value)||3;
  const system=document.getElementById("system").value;
  const container=document.getElementById("drawerSelectors");

  drawerSection.style.display=(config==="Szuflady")?"block":"none";
  container.innerHTML="";
  if(config!=="Szuflady") return;

  renderLayoutButtons();

  const H=parseInt(document.getElementById("height").value)||720;
  const golaOffset=(document.getElementById("type").value==="Dolna GOLA")?50:0;
  const available=H-golaOffset-4-((qty-1)*3);
  const autoFrontH=Math.max(100, Math.floor(available/qty));

  // ===   (D-D-M  ..) ===
  const typeKeys=Object.keys(systemData[system].types);
  const typePresets=[];

  //  :   + 
  if(qty===1){
    typeKeys.forEach(t=>typePresets.push({label:t, types:[t]}));
  } else if(qty===2){
    typeKeys.forEach(t=>typePresets.push({label:`${t}-${t}`, types:[t,t]}));
    // :   +  
    for(let a=0;a<typeKeys.length;a++)
      for(let b=a+1;b<typeKeys.length;b++)
        typePresets.push({label:`${typeKeys[a]}-${typeKeys[b]}`, types:[typeKeys[a],typeKeys[b]]});
  } else if(qty===3){
    typeKeys.forEach(t=>typePresets.push({label:`${t}-${t}-${t}`, types:[t,t,t]}));
    // 2  + 1  (  = szuflada 1)
    for(let big=typeKeys.length-1;big>0;big--)
      for(let sm=0;sm<big;sm++)
        typePresets.push({label:`${typeKeys[big]}-${typeKeys[big]}-${typeKeys[sm]}`, types:[typeKeys[big],typeKeys[big],typeKeys[sm]]});
  } else if(qty===4){
    typeKeys.forEach(t=>typePresets.push({label:`${t}×4`, types:[t,t,t,t]}));
    for(let big=typeKeys.length-1;big>0;big--)
      typePresets.push({label:`${typeKeys[big]}×3+${typeKeys[0]}`, types:[typeKeys[big],typeKeys[big],typeKeys[big],typeKeys[0]]});
  }

